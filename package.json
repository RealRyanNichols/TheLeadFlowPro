{
  "name": "leadflow-pro",
  "version": "0.1.0",
  "private": true,
  "description": "LeadFlow Pro - public lead intelligence, source-backed profiles, and market-signal data products. theleadflowpro.com",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/audit-internal-links.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run audit:analytics && npm run audit:env && npm run build",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "audit:links": "node scripts/audit-internal-links.mjs",
    "audit:analytics": "node scripts/audit-analytics-privacy.mjs",
    "audit:env": "node scripts/audit-public-env.mjs",
    "audit:paid-links": "node scripts/audit-paid-traffic-links.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.0.14",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "stripe": "^22.0.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
