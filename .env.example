# --- Lead Intelligence / Organic Radar ---
# Optional. PageSpeed can run without a key at low volume, but a key gives better quota.
GOOGLE_PAGESPEED_API_KEY=""
# Optional. Enables /admin/radar to seed local prospects from Google Places API.
GOOGLE_PLACES_API_KEY=""

# --- Twilio (Missed-Call Auto Text-Back + inbound SMS) ---
# Create a sub-account, buy a number, enable SMS on it, then set the
# Voice + Messaging webhooks to the URLs shown on
# /dashboard/leads/missed-call (per-user).
# If these are empty, sendSms() logs the payload and returns { skipped: true }
# so development + preview deploys don't explode.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
