# --- Database (Postgres). Free tier: https://neon.tech ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- OAuth providers (add when ready) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Social platform OAuth (placeholders for future use) ---
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

# --- Twilio (Missed-Call Auto Text-Back + inbound SMS) ---
# Create a sub-account, buy a number, enable SMS on it, then set the
# Voice + Messaging webhooks to the URLs shown on
# /dashboard/leads/missed-call (per-user).
# If these are empty, sendSms() logs the payload and returns { skipped: true }
# so development + preview deploys don't explode.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
